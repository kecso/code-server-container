#!/usr/bin/with-contenv bash
# shellcheck shell=bash
# Bind mounts (e.g. Portainer) often create /config/data, /config/extensions, or
# /config/workspace on the host as root. code-server runs as abc and must own these.
set -e

fix_if_wrong_owner() {
  local d="$1"
  if [[ ! -d "$d" ]]; then
    return 0
  fi
  local want
  want="$(id -u abc):$(id -g abc)"
  if [[ "$(stat -c '%u:%g' "$d")" != "$want" ]]; then
    chown -R abc:abc "$d"
  fi
}

fix_if_wrong_owner /config/data
fix_if_wrong_owner /config/extensions
fix_if_wrong_owner /config/workspace
